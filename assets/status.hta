<html>
<head>
<HTA:APPLICATION
  ID="AEGISStatus"
  APPLICATIONNAME="AEGIS Status"
  CAPTION="no"
  SHOWINTASKBAR="no"
  SYSMENU="no"
  SCROLL="no"
  BORDER="none"
  BORDERSTYLE="none"
  WINDOWSTATE="normal"
  SINGLEINSTANCE="yes"
/>
<meta http-equiv="X-UA-Compatible" content="IE=edge"/>
<title>AEGIS Status</title>
<link rel="stylesheet" href="status.css"/>
<style>
html, body { width: 320px; height: auto; min-height: 380px; }
</style>
</head>
<body>

<!-- [A] Header -->
<div class="header" id="header">
  <div class="header-left">
    <span style="font-size:16px">⬡</span>
    <span class="header-title">AEGIS</span>
  </div>
  <div style="display:flex;align-items:center;gap:8px">
    <span class="header-version" id="header-version">2.0</span>
    <button class="header-close" onclick="window.close()">✕</button>
  </div>
</div>

<!-- [B] Profile badge -->
<div class="profile-badge" onclick="toggleProfileSwitcher()">
  <div class="profile-badge-inner">
    <span class="profile-dot" id="profile-dot" style="background:#6b7280"></span>
    <div>
      <div class="profile-name" id="profile-name">Loading...</div>
      <div class="profile-desc" id="profile-desc"></div>
    </div>
  </div>
  <div class="profile-switcher" id="profile-switcher"></div>
</div>

<!-- [B2] Elevation warning (shown only when not elevated) -->
<div id="elevation-warning" style="display:none;background:#78350f;color:#fef3c7;font-size:11px;padding:4px 12px;">
  ⚠ No elevation — resource control inactive
</div>

<!-- [C] System vitals -->
<div class="vitals">
  <div class="vital-row">
    <span class="vital-label">CPU</span>
    <div class="vital-bar-wrap"><div class="vital-bar" id="cpu-bar" style="width:0%"></div></div>
    <span class="vital-value" id="cpu-val">—</span>
  </div>
  <div class="vital-row">
    <span class="vital-label">RAM</span>
    <div class="vital-bar-wrap"><div class="vital-bar" id="ram-bar" style="width:0%"></div></div>
    <span class="vital-value" id="ram-val">—</span>
  </div>
  <div class="vital-row">
    <span class="vital-label">PWR</span>
    <span class="vital-text" id="pwr-val">—</span>
  </div>
</div>

<!-- [D] Elevated processes -->
<div class="process-section" id="elevated-section" style="display:none">
  <div class="section-header">
    <span class="section-label">Elevated</span>
    <span class="section-count" id="elevated-count">0</span>
  </div>
  <div id="elevated-list"></div>
</div>

<!-- [E] Throttled processes -->
<div class="process-section" id="throttled-section" style="display:none">
  <div class="section-header">
    <span class="section-label">Throttled</span>
    <span class="section-count" id="throttled-count">0</span>
  </div>
  <div id="throttled-list"></div>
</div>

<!-- [F] System health -->
<div class="health">
  <div class="health-item">
    <span class="health-dot health-offline" id="worker-dot"></span>
    <span>Worker</span>
    <span id="worker-text" style="color:var(--text-muted);margin-left:4px">—</span>
  </div>
  <div class="health-item">
    <span class="health-dot health-offline" id="kernl-dot"></span>
    <span>KERNL</span>
    <span id="kernl-text" style="color:var(--text-muted);margin-left:4px">—</span>
  </div>
</div>

<!-- [G] Timer -->
<div class="timer-row">
  <span class="timer-text" id="timer-text">⏱ No timer active</span>
  <button class="timer-btn" id="timer-btn" onclick="showTimerForm()">Set Timer</button>
</div>
<div class="timer-set-form" id="timer-form" style="padding:0 12px 8px">
  <span style="font-size:12px;color:var(--text-muted)">Switch to</span>
  <select id="timer-profile-sel"></select>
  <span style="font-size:12px;color:var(--text-muted)">for</span>
  <input type="number" id="timer-duration" value="60" min="1" max="480" style="width:52px"/>
  <span style="font-size:12px;color:var(--text-muted)">min</span>
  <button class="timer-btn" onclick="setTimer()">Set</button>
  <button class="timer-btn" onclick="hideTimerForm()">✕</button>
</div>

<!-- [K] Browser tab panel -->
<div class="process-section" id="browser-section" style="display:none">
  <div class="section-header">
    <span class="section-label" id="browser-header-label">BRAVE</span>
    <span class="section-count" id="browser-memory-badge"></span>
  </div>
  <div id="browser-tab-list"></div>
</div>

<!-- [H] Quick-switch dots -->
<div class="quick-switch" id="quick-switch"></div>

<!-- [I] History strip -->
<div class="history-strip" id="history-strip"></div>

<!-- [J] Footer -->
<div class="footer">
  <button class="footer-link" onclick="openSettings()">Settings</button>
  <button class="footer-link" onclick="openSettings()">About</button>
</div>

<script src="status.js"></script>
<script>
window.onload = function() {
  initDrag(document.getElementById('header'))
  startPolling()
  // Position window: bottom-right above taskbar
  var screenW = screen.availWidth
  var screenH = screen.availHeight
  window.moveTo(screenW - 340, screenH - 420)
}
window.onunload = function() { stopPolling() }
</script>
</body>
</html>