<html>
<head>
<HTA:APPLICATION
  ID="AEGISSettings"
  APPLICATIONNAME="AEGIS Settings"
  CAPTION="yes"
  SHOWINTASKBAR="yes"
  SYSMENU="yes"
  SCROLL="no"
  BORDER="normal"
  SINGLEINSTANCE="yes"
/>
<meta http-equiv="X-UA-Compatible" content="IE=edge"/>
<title>AEGIS Settings</title>
<link rel="stylesheet" href="status.css"/>
<style>
html { height: 100%; } body { height: 100%; width: 540px; min-height: 600px; }
</style>
</head>
<body class="settings-body">

<!-- Tabs -->
<div class="tabs">
  <button class="tab-btn active" data-tab="general" onclick="switchTab('general')"
    data-tooltip="General settings — default profile, status window, auto-detection, and notifications."
    data-tooltip-pos="below">General</button>
  <button class="tab-btn" data-tab="profiles" onclick="switchTab('profiles')"
    data-tooltip="View and manage loaded profiles. Edit YAML configs or reset profiles to their defaults."
    data-tooltip-pos="below">Profiles</button>
  <button class="tab-btn" data-tab="integrations" onclick="switchTab('integrations')"
    data-tooltip="Configure KERNL integration and the AEGIS MCP server for Claude Desktop."
    data-tooltip-pos="below">Integrations</button>
  <button class="tab-btn" data-tab="startup" onclick="switchTab('startup')"
    data-tooltip="Manage the Windows Task Scheduler startup entry and test the worker process."
    data-tooltip-pos="below">Startup</button>
  <button class="tab-btn" data-tab="about" onclick="switchTab('about')"
    data-tooltip="Version info, update check, debug copy, and log folder access."
    data-tooltip-pos="below">About</button>
</div>

<!-- General Tab -->
<div class="tab-content active" id="tab-general">
  <div class="settings-section">
    <h3>Default Profile</h3>
    <div class="settings-row">
      <label>Default profile</label>
      <select id="setting-default-profile"
        data-tooltip="The profile AEGIS applies on startup and after a timer expires with no other override active."><option>idle</option></select>
    </div>
    <div class="settings-note">Applied on startup and after timer/auto-detection.</div>
  </div>
  <div class="settings-section">
    <h3>Status Window</h3>
    <div class="settings-row">
      <label>Open status window on startup</label>
      <input type="checkbox" id="setting-auto-open"
        data-tooltip="When checked, the status window opens automatically when AEGIS starts. Uncheck to keep it hidden until you left-click the tray icon."/>
    </div>
    <div class="settings-row">
      <label>Status window port (advanced)</label>
      <input type="number" id="setting-port" value="8743"
        data-tooltip="The local HTTP port AEGIS uses to serve the status window. Change this only if port 8743 conflicts with another application. Requires AEGIS restart."/>
    </div>
  </div>
  <div class="settings-section">
    <h3>Auto-Detection</h3>
    <div class="settings-row">
      <label>Enable auto-detection</label>
      <input type="checkbox" id="setting-auto-detect"
        data-tooltip="When enabled, AEGIS watches running applications and suggests or automatically switches profiles based on what you are doing."/>
    </div>
    <div class="settings-row">
      <label>Mode</label>
      <select id="setting-detect-mode"
        data-tooltip="Suggest: AEGIS sends a notification asking if you want to switch. Switch automatically: AEGIS switches without asking, subject to the cooldown period.">
        <option value="suggest">Suggest with notification</option>
        <option value="auto">Switch automatically</option>
      </select>
    </div>
    <div class="settings-note">AEGIS watches running apps and suggests or switches profiles automatically.</div>
  </div>
  <div class="settings-section">
    <h3>Notifications</h3>
    <div class="settings-row">
      <label>Profile switch notifications</label>
      <input type="checkbox" id="notif-switch"
        data-tooltip="Show a Windows toast notification whenever the active profile changes. Off by default to reduce noise."/>
    </div>
    <div class="settings-row">
      <label>Timer expired notifications</label>
      <input type="checkbox" id="notif-timer" checked
        data-tooltip="Show a notification when a timed profile switch completes. On by default so you know the timer fired."/>
    </div>
    <div class="settings-row">
      <label>Watchdog restart notifications</label>
      <input type="checkbox" id="notif-watchdog" checked
        data-tooltip="Show a notification when the watchdog restarts a monitored process. On by default — indicates AEGIS is actively managing a crash."/>
    </div>
    <div class="settings-row">
      <label>Worker crash notifications</label>
      <input type="checkbox" id="notif-worker" checked
        data-tooltip="Show a persistent notification if the AEGIS worker process crashes. On by default — resource management is inactive when the worker is down."/>
    </div>
    <div class="settings-row">
      <label>KERNL state change notifications</label>
      <input type="checkbox" id="notif-kernl"
        data-tooltip="Show a notification when KERNL connects or disconnects. Off by default — KERNL being offline is not an error condition."/>
    </div>
  </div>
</div>

<!-- Profiles Tab -->
<div class="tab-content" id="tab-profiles">
  <div id="profile-list" style="margin-bottom:12px"></div>
  <div style="display:flex;gap:8px;margin-top:8px">
    <button class="settings-btn"
      data-tooltip="Import a profile from a .yaml file. AEGIS validates the file and copies it to %APPDATA%\AEGIS\profiles\. Reloads automatically — no restart needed.">+ Import Profile...</button>
    <button class="settings-btn" onclick="openProfilesFolder()"
      data-tooltip="Open the profiles folder in Windows Explorer (%APPDATA%\AEGIS\profiles\). Add, edit, or delete .yaml files here. AEGIS detects changes automatically.">Open Profiles Folder</button>
  </div>
</div>

<!-- Integrations Tab -->
<div class="tab-content" id="tab-integrations">
  <div class="settings-section">
    <h3>KERNL</h3>
    <div class="settings-row">
      <label>Enable KERNL integration</label>
      <input type="checkbox" id="kernl-enabled" checked
        data-tooltip="When enabled, AEGIS connects to the local KERNL session manager to receive context hints. Optional — AEGIS works fully without KERNL."/>
    </div>
    <div class="settings-row">
      <label>Host</label>
      <input type="text" id="kernl-host" value="localhost" style="width:120px"
        data-tooltip="KERNL host address. Leave as localhost unless KERNL is running on a different machine."/>
    </div>
    <div class="settings-row">
      <label>Port</label>
      <input type="number" id="kernl-port" value="3001" style="width:80px"
        data-tooltip="KERNL port. Default is 3001. Change only if you have configured KERNL to use a different port."/>
    </div>
    <div style="margin-top:8px;display:flex;gap:10px;align-items:center">
      <button class="settings-btn" onclick="testKernl()"
        data-tooltip="Send a health-check ping to KERNL and report the connection result. Does not change any settings.">Test Connection</button>
      <span id="kernl-status" class="status-indicator" id="kernl-test-result"></span>
    </div>
  </div>
  <div class="settings-section">
    <h3>AEGIS MCP Server</h3>
    <div class="settings-row">
      <label>Enable MCP Server</label>
      <input type="checkbox" id="mcp-enabled" checked
        data-tooltip="Exposes AEGIS as an MCP tool server so Claude Desktop can query system state and switch profiles via natural language."/>
    </div>
    <div class="settings-row">
      <label>Port</label>
      <input type="number" id="mcp-port" value="3742" style="width:80px"
        data-tooltip="MCP server port. Default is 3742. Must match the port in your Claude Desktop MCP config. Requires AEGIS restart to take effect."/>
    </div>
    <div style="margin-top:8px">
      <div style="font-size:12px;color:var(--text-muted);margin-bottom:6px">Claude Desktop config (copy this into claude_desktop_config.json):</div>
      <div class="code-block">"aegis": {<br>&nbsp;&nbsp;"command": "C:\\Program Files\\AEGIS\\AEGIS.exe",<br>&nbsp;&nbsp;"args": ["--mcp"]<br>}</div>
      <button class="settings-btn" id="copy-mcp-btn" onclick="copyMcpConfig()"
        data-tooltip="Copy the MCP server config block to the clipboard. Paste this into your claude_desktop_config.json to connect Claude Desktop to AEGIS.">Copy to Clipboard</button>
    </div>
    <div style="margin-top:8px">
      <span class="status-indicator">MCP Server: <span id="mcp-status" style="margin-left:6px">—</span></span>
    </div>
  </div>
</div>

<!-- Startup Tab -->
<div class="tab-content" id="tab-startup">
  <div class="settings-section">
    <h3>Task Scheduler</h3>
    <div class="settings-row"><label>Task name</label><span style="color:var(--text-muted)">AEGIS_Startup</span></div>
    <div style="margin-top:8px;display:flex;gap:8px">
      <button class="settings-btn"
        data-tooltip="Check that the AEGIS startup task exists in Windows Task Scheduler and is enabled. Reports status without making any changes.">Verify Task</button>
      <button class="settings-btn"
        data-tooltip="Re-run the install-task.ps1 script to recreate the startup task. Use this if Verify Task reports the task is missing or broken.">Repair Task</button>
      <button class="settings-btn"
        data-tooltip="Remove the startup task from Task Scheduler. AEGIS will no longer start automatically at logon. You can still launch it manually. Irreversible without Repair.">Remove Task</button>
    </div>
  </div>
  <div class="settings-section">
    <h3>Worker</h3>
    <div class="settings-row">
      <label>Transport</label>
      <select
        data-tooltip="How the main AEGIS process communicates with the worker sidecar. stdin/stdout is the default and works for most setups. Named pipe is an advanced option for specific deployment scenarios.">
        <option>stdin/stdout</option>
        <option>Named pipe (advanced)</option>
      </select>
    </div>
    <div style="margin-top:8px;display:flex;gap:10px;align-items:center">
      <button class="settings-btn"
        data-tooltip="Send a ping to the worker process and display the round-trip latency. Confirms the worker is alive and responsive.">Test Worker</button>
      <span id="worker-test-result" style="font-size:12px;color:var(--text-muted)"></span>
    </div>
  </div>
</div>

<!-- About Tab -->
<div class="tab-content" id="tab-about">
  <div class="about-section">
    <div class="about-title">AEGIS</div>
    <div class="about-subtitle">Cognitive Resource Manager</div>
    <div style="color:var(--text-muted);font-size:13px;margin-bottom:16px">Version 2.0.0</div>
    <div style="display:flex;gap:8px;justify-content:center;margin-bottom:16px">
      <button class="settings-btn"
        data-tooltip="Check GitHub for a newer version of AEGIS. Opens the releases page or shows a download prompt if an update is available.">Check for Updates</button>
    </div>
    <div style="color:var(--text-muted);font-size:12px;margin-bottom:8px">
      GitHub: <a href="https://github.com/duke-of-beans/AEGIS" style="color:var(--accent)">github.com/duke-of-beans/AEGIS</a>
    </div>
    <div style="display:flex;gap:8px;justify-content:center;margin-top:16px">
      <button class="settings-btn" onclick="openLogFolder()"
        data-tooltip="Open the AEGIS log folder in Windows Explorer (%APPDATA%\AEGIS\logs\). Contains daily rotating log files for the main process and worker.">Open Log Folder</button>
      <button class="settings-btn" onclick="copyDebugInfo()"
        data-tooltip="Copy AEGIS version, active config, loaded profiles, and the last 20 log lines to the clipboard. Paste this into a bug report or support request.">Copy Debug Info</button>
    </div>
  </div>
</div>

<script src="status.js"></script>
<script>
window.onload = function() {
  // Load current settings from status API
  httpGet(BASE_URL + '/status', function(err, data) {
    if (data) { currentSnapshot = data }
  })
  // Load profiles for General tab dropdown
  httpGet(BASE_URL + '/profiles', function(err, data) {
    if (!err && data) {
      allProfiles = data
      var sel = document.getElementById('setting-default-profile')
      if (sel) {
        sel.innerHTML = ''
        data.forEach(function(p) {
          var opt = document.createElement('option')
          opt.value = p.name
          opt.textContent = p.display_name
          sel.appendChild(opt)
        })
      }
    }
  })
}

function loadProfilesTab() {
  httpGet(BASE_URL + '/profiles', function(err, data) {
    if (err || !data) return
    var list = document.getElementById('profile-list')
    if (!list) return
    list.innerHTML = ''
    data.forEach(function(p) {
      var item = document.createElement('div')
      item.className = 'profile-list-item'

      // Build browser suspension CDP port row if profile has browser_suspension
      var cdpRow = ''
      if (p.browser_suspension) {
        var cdpVal = (p.browser_suspension.cdp_port !== undefined && p.browser_suspension.cdp_port !== null)
          ? p.browser_suspension.cdp_port : 9222
        cdpRow =
          '<div class="settings-row" style="margin-top:6px;font-size:12px">' +
            '<label style="font-size:12px;color:var(--text-muted)">CDP Port</label>' +
            '<input type="number" min="1024" max="65535" step="1"' +
              ' id="cdp-port-' + p.name + '"' +
              ' value="' + cdpVal + '"' +
              ' style="width:70px;font-size:12px"' +
              ' data-tooltip="Remote debugging port Brave was launched with.' +
                ' Run multiple Brave instances on different ports to isolate profiles."/>' +
            '<button class="settings-btn" style="font-size:11px;padding:2px 8px"' +
              ' onclick="saveCdpPort(\'' + p.name + '\')"' +
              ' data-tooltip="Save CDP port for this profile. Takes effect on next profile activation.">' +
              'Save' +
            '</button>' +
          '</div>'
      }

      item.innerHTML =
        '<span class="profile-list-dot" style="background:' + p.color + '"></span>' +
        '<div style="flex:1">' +
          '<div class="profile-list-name">' + p.display_name + '</div>' +
          '<div class="profile-list-desc">' + (p.description || '') + '</div>' +
          cdpRow +
        '</div>' +
        '<div class="profile-list-actions">' +
          '<button class="settings-btn" onclick="editProfile(\'' + p.name + '\')" data-tooltip="Open ' + p.display_name + '.yaml in your default editor. AEGIS reloads the profile automatically on save — no restart needed.">Edit</button>' +
          '<button class="settings-btn" onclick="resetProfile(\'' + p.name + '\')" data-tooltip="Reset ' + p.display_name + ' to its factory defaults. Your customizations will be permanently lost. A confirmation prompt will appear first.">Reset</button>' +
        '</div>'
      list.appendChild(item)
    })
  })
}

function saveCdpPort(profileName) {
  var input = document.getElementById('cdp-port-' + profileName)
  if (!input) return
  var port = parseInt(input.value, 10)
  if (isNaN(port) || port < 1024 || port > 65535) {
    alert('CDP port must be between 1024 and 65535.')
    return
  }
  httpPost(BASE_URL + '/profiles/' + encodeURIComponent(profileName) + '/browser-suspension',
    { cdp_port: port },
    function(err) {
      if (err) {
        alert('Could not save CDP port. Check AEGIS is running.')
      } else {
        var btn = input.nextSibling
        if (btn) { btn.textContent = 'Saved!'; setTimeout(function() { btn.textContent = 'Save' }, 2000) }
      }
    }
  )
}
</script>
</body>
</html>
