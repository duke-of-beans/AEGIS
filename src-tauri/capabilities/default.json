{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "AEGIS default capabilities",
  "windows": ["cockpit"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/aegis-sidecar",
          "sidecar": true
        }
      ]
    }
  ]
}
