{
  "name": "aegis",
  "version": "2.1.0",
  "description": "AEGIS — Cognitive Resource Manager for the Windows AI Workstation",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build:ts": "tsc --noEmit && tsc",
    "build": "tsc && node build-release.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "release": "node build-release.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "systray2": "^2.1.4",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "pkg": "^5.8.1",
    "typescript": "^5.3.3"
  },
  "pkg": {
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "release",
    "assets": [
      "release/assets/**/*",
      "release/profiles/**/*",
      "release/scripts/**/*"
    ]
  }
}
