{
  "name": "aegis-sidecar",
  "version": "4.0.0",
  "description": "AEGIS Intelligence Sidecar — context engine, sniper, learning, catalog, MCP",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "bundle": "npx @yao-pkg/pkg . --target node20-win-x64 --output ../src-tauri/binaries/aegis-sidecar-x86_64-pc-windows-msvc.exe",
    "build-and-bundle": "tsc && npx @yao-pkg/pkg . --target node20-win-x64 --output ../src-tauri/binaries/aegis-sidecar-x86_64-pc-windows-msvc.exe",
    "dev": "node dist/main.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "js-yaml": "^4.1.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "pkg": "^5.8.1",
    "typescript": "^5.3.3"
  },
  "pkg": {
    "assets": [
      "dist/**/*"
    ],
    "targets": [
      "node20-win-x64"
    ]
  },
  "bin": "dist/main.js"
}
