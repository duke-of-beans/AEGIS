{
  "name": "aegis-sidecar",
  "version": "4.0.0",
  "description": "AEGIS Intelligence Sidecar — context engine, sniper, learning, catalog, MCP",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "build": "tsc --noEmit && tsc",
    "bundle": "pkg . --target node20-win-x64 --output ../src-tauri/binaries/aegis-sidecar-x86_64-pc-windows-msvc.exe",
    "dev": "npx ts-node --esm src/main.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "js-yaml": "^4.1.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "pkg": "^5.8.1",
    "typescript": "^5.3.3"
  },
  "pkg": {
    "targets": ["node20-win-x64"],
    "outputPath": "../src-tauri/binaries",
    "assets": ["src/**/*"]
  }
}
